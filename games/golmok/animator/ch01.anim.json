{
  "schema": "SandEngine.Animator.v1",
  "sprite": "ch01_player",
  "default": "idle",

  "parameters": [
    { "name": "speed",   "type": "float",   "default": 0 },
    { "name": "running", "type": "bool",    "default": false },
    { "name": "fire",    "type": "trigger" },
    { "name": "firing",  "type": "bool",    "default": false }
  ],

  "transitions": [
    { "from": "idle",     "to": "walk",     "conditions": [ { "p": "speed", "op": ">",  "v": 0.1 } ] },
    { "from": "walk",     "to": "idle",     "conditions": [ { "p": "speed", "op": "<=", "v": 0.1 } ] },
    { "from": "walk",     "to": "run",      "conditions": [ { "p": "speed", "op": ">",  "v": 0.1 }, { "p": "running", "op": "==", "v": true } ] },
    { "from": "run",      "to": "run_stop", "conditions": [ { "p": "running", "op": "==", "v": false } ] },
    { "from": "run",      "to": "run_stop", "conditions": [ { "p": "speed",   "op": "<=", "v": 0.1 } ] },
    { "from": "run_stop", "to": "idle",     "hasExitTime": true }
  ]
}
